{
  "name": "trainsetgo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hex Train Routing Puzzle Game - static web app",
  "scripts": {
    "serve": "node scripts/serve.mjs",
    "make-models": "node scripts/make-models.mjs",
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "test:model": "node --test \"tests/model/**/*.test.js\"",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:model && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0"
  }
}
